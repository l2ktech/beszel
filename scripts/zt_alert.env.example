# zt_latency_sync.sh optional alert config
# This file is sourced by scripts/zt_latency_sync.sh if present as scripts/zt_alert.env

# Enable or disable network alerts
ALERTS_ENABLED=true

# Offline alert when continuous -1 count reaches this value
ALERT_OFFLINE_STREAK=2

# Jitter alert when abs(current_ms - previous_ms) exceeds this threshold (ms)
ALERT_JITTER_WARN_MS=80

# Jitter alert requires consecutive high-jitter samples
ALERT_JITTER_STREAK=3

# Same alert type cooldown in seconds
ALERT_COOLDOWN_SEC=600

# Optional regex filter by system name (empty = all systems)
# ALERT_SYSTEM_FILTER_REGEX=^friendlyWrt$

# DingTalk robot (optional)
# ALERT_DINGTALK_TOKEN=your_access_token
# ALERT_DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALERT_DINGTALK_KEYWORD=13pro
